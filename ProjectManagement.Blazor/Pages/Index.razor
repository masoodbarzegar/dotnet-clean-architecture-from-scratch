@page "/"
@inject HttpClient Http
@inject NavigationManager Nav

<h1>Index Loaded</h1>


@if (_isLoading)
{
    <p>Loading projects...</p>
}
else if (_error != null)
{
    <div class="alert alert-danger">
        <strong>Something went wrong</strong>
        <p>@_error</p>
    </div>
}
else if (_projects == null && !_isLoading )
{
     <p>No data</p>
}
else
{
    <div class="d-flex gap-2 mb-3">
        <input class="form-control"
               placeholder="Search projects..."
               value="@_search"
               @oninput="OnSearchInput" />

        <select class="form-select w-auto"
                value="@_sort"
                @onchange="OnSortChanged">
            <option value="name">Name (A–Z)</option>
            <option value="name_desc">Name (Z–A)</option>
        </select>
    </div>

    <ul>
        @foreach (var p in _projects!.Items)
        {
            <li>@p.DisplayName</li>
        }
    </ul>
    @if (_projects != null && TotalPages > 1)
    {
        <div class="d-flex align-items-center gap-2 mt-3">
            <button class="btn btn-secondary"
                    @onclick="PrevPage"
                    disabled="@(_currentPage == 1 || _isLoading)">
                ◀ Prev
            </button>

            <span>
                Page @_currentPage of @TotalPages
            </span>

            <button class="btn btn-secondary"
                    @onclick="NextPage"
                    disabled="@(_currentPage == TotalPages || _isLoading)">
                Next ▶
            </button>
        </div>
    }

}

@code {
    private ProjectsResponse? _projects;
    private bool _isLoading;
    private string? _error;

    private string? _search;
    private string _sort = "name";

    private CancellationTokenSource? _searchCts;

    private string? Search
    {
        get => _search;
        set
        {
            if (_search == value) return;
            _search = value;
            _currentPage = 1;
            _ = LoadProjectsAsync();
        }
    }
    private string Sort
    {
        get => _sort;
        set
        {
            if (_sort == value) return;
            _sort = value;
            _currentPage = 1;
            _ = LoadProjectsAsync();
        }
    }

    private int _currentPage = 1;
    private int _pageSize = 5;

    private int TotalPages =>
        _projects == null
            ? 0
            : (int)Math.Ceiling(
                _projects.TotalCount / (double)_pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectsAsync();
    }

    private async Task LoadProjectsAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            var query = new List<string>
            {
                $"page={_currentPage}",
                $"pageSize={_pageSize}",
                $"sort={_sort}"
            };
            
            if (!string.IsNullOrWhiteSpace(_search))
                query.Add($"search={Uri.EscapeDataString(_search ?? "")}");

            var url = "projects?" + string.Join("&", query);

            _projects = await Http.GetFromJsonAsync<ProjectsResponse>(url);

        }
        catch (HttpRequestException)
        {
            _error = "Unable to load projects. Please try again.";
        }
        catch (Exception)
        {
            _error = "Unexpected error occurred.";
        }
        finally
        {
            _isLoading = false;
        }

        // UpdateQueryString();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString();
        _currentPage = 1;

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(400, _searchCts.Token); // debounce
            await LoadProjectsAsync();
        }
        catch (TaskCanceledException)
        {
            // user typed again – ignore
        }
    }

    private async Task OnSortChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (value == _sort) return;

        _sort = value ?? "name";
        _currentPage = 1;
        await LoadProjectsAsync();
    }

    private void UpdateQueryString()
    {
        var query = new Dictionary<string, object?>
        {
            ["page"] = _currentPage,
            ["pageSize"] = _pageSize,
            ["sort"] = Sort,
            ["search"] = Search
        };

        Nav.NavigateTo(
            Nav.GetUriWithQueryParameters(query),
            replace: true);
    }

    private async Task PrevPage()
    {
        if (_currentPage <= 1) return;

        _currentPage--;
        await LoadProjectsAsync();
    }

    private async Task NextPage()
    {
        if (_currentPage >= TotalPages) return;

        _currentPage++;
        await LoadProjectsAsync();
    }

    public class ProjectsResponse
    {
        public List<ProjectItem> Items { get; set; } = [];
        public int TotalCount { get; set; }
    }

    public class ProjectItem
    {
        public string ProjectId { get; set; } = "";
        public string DisplayName { get; set; } = "";
    }
}