@page "/"
@inject HttpClient Http

<h1>Index Loaded</h1>


@if (_isLoading)
{
    <p>Loading projects...</p>
}
else if (_error != null)
{
    <div class="alert alert-danger">
        <strong>Something went wrong</strong>
        <p>@_error</p>
    </div>
}
else if (_projects == null && !_isLoading )
{
     <p>No data</p>
}
else
{
    <ul>
        @foreach (var p in _projects.Items)
        {
            <li>@p.DisplayName</li>
        }
    </ul>
    @if (_projects != null && TotalPages > 1)
    {
        <div class="d-flex align-items-center gap-2 mt-3">
            <button class="btn btn-secondary"
                    @onclick="PrevPage"
                    disabled="@(_currentPage == 1 || _isLoading)">
                ◀ Prev
            </button>

            <span>
                Page @_currentPage of @TotalPages
            </span>

            <button class="btn btn-secondary"
                    @onclick="NextPage"
                    disabled="@(_currentPage == TotalPages || _isLoading)">
                Next ▶
            </button>
        </div>
    }

}

@code {
    private ProjectsResponse? _projects;
    private bool _isLoading;
    private string? _error;

    private int _currentPage = 1;
    private int _pageSize = 5;

    private int TotalPages =>
        _projects == null
            ? 0
            : (int)Math.Ceiling(
                _projects.TotalCount / (double)_pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectsAsync();
    }

    private async Task LoadProjectsAsync()
    {
        _isLoading = true;
        _error = null;

        try
        {
            _projects = await Http.GetFromJsonAsync<ProjectsResponse>(
                $"projects?page={_currentPage}&pageSize={_pageSize}");
        }
        catch (HttpRequestException)
        {
            _error = "Unable to load projects. Please try again.";
        }
        catch (Exception)
        {
            _error = "Unexpected error occurred.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task PrevPage()
    {
        if (_currentPage <= 1) return;

        _currentPage--;
        await LoadProjectsAsync();
    }

    private async Task NextPage()
    {
        if (_currentPage >= TotalPages) return;

        _currentPage++;
        await LoadProjectsAsync();
    }

    public class ProjectsResponse
    {
        public List<ProjectItem> Items { get; set; } = [];
        public int TotalCount { get; set; }
    }

    public class ProjectItem
    {
        public string ProjectId { get; set; } = "";
        public string DisplayName { get; set; } = "";
    }
}